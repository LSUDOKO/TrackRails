# ─────────────────────────────────────────────────────────────────────
# Track Rails — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── Story Protocol (Aeneid Testnet) ──────────────────────────────────

# JSON-RPC endpoint for reading/writing to the blockchain.
NEXT_PUBLIC_RPC_URL=https://rpc.ankr.com/story_aeneid_testnet

# Story REST API URL (Cosmos SDK port 1317).
# This is REQUIRED for CDR threshold encryption (DKG endpoints like
# /dkg/latest_active, /dkg/cdr_partials, etc.) which are NOT served
# by the JSON-RPC endpoint.
#
# Local development: http://172.192.41.96:1317
# Production: needs to be a PUBLICLY accessible Story node REST API.
#             If you don't have one, leave this commented out — the
#             CDR vault creation step will use the same-origin proxy
#             (which falls back to the JSON-RPC server and won't have
#             DKG endpoints, causing 404 errors).
NEXT_PUBLIC_STORY_API_URL=http://172.192.41.96:1317

# ── WalletConnect ───────────────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ── Network ─────────────────────────────────────────────────────────
NEXT_PUBLIC_NETWORK=testnet

# ── Smart Contracts (deployed on Aeneid) ────────────────────────────
# Deployed with: forge script script/DeployTrackRails.s.sol --broadcast
NEXT_PUBLIC_TRACK_RAILS_PROTOCOL=
NEXT_PUBLIC_TRACK_NFT=
# Optional: only needed if you use playlists
NEXT_PUBLIC_PLAYLIST_CONTRACT=

# ── Pinata (IPFS Pinning) ───────────────────────────────────────────
# Get your JWT at https://app.pinata.cloud/developers/api-keys
#
# PINATA_JWT: server-side, used by /api/ipfs/upload route & JWT fallback.
#             Set this in Vercel env vars (NOT exposed to browser).
PINATA_JWT=
#
# NEXT_PUBLIC_PINATA_JWT: inlined at build time for client-side direct
#                         Pinata uploads. This bypasses Vercel's 4.5 MB
#                         body limit on serverless functions.
#                         Set this in .env.local AND Vercel env vars.
NEXT_PUBLIC_PINATA_JWT=

# ── Story RPC (for CDR SDK) ─────────────────────────────────────────
# The CDR SDK needs both the JSON-RPC endpoint (above) and the
# Story REST API (above) to operate. The REST API must be accessible
# from wherever your frontend is deployed (Vercel, your server, etc.).
