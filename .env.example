# Story Protocol — Aeneid Testnet
NEXT_PUBLIC_RPC_URL=https://rpc.ankr.com/story_aeneid_testnet
NEXT_PUBLIC_STORY_API_URL=https://your-story-api-url:1317

# WalletConnect — get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Network
NEXT_PUBLIC_NETWORK=testnet

# Track Rails contracts (deployed on Aeneid)
NEXT_PUBLIC_TRACK_RAILS_PROTOCOL=
NEXT_PUBLIC_TRACK_NFT=

# Pinata — IPFS pinning JWT (get at https://app.pinata.cloud/developers/api-keys)
PINATA_JWT=

# TrackRailsPlaylist contract (optional)
NEXT_PUBLIC_PLAYLIST_CONTRACT=
