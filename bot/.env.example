# Telegram Bot Token (from @BotFather)
# Get yours at https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# Blockchain RPC — Story Aeneid testnet
NEXT_PUBLIC_RPC_URL=https://rpc.ankr.com/story_aeneid_testnet

# Track Rails Protocol contract address
NEXT_PUBLIC_TRACK_RAILS_PROTOCOL=0x8Ea69442fFeb34Cac9cE380A8B77E4b29DABe36c

# Site URL for deep links to the web app
NEXT_PUBLIC_SITE_URL=https://audiorails.vercel.app

# Bot mode: "polling" (default) or "webhook"
BOT_MODE=polling

# Required if BOT_MODE=webhook
# WEBHOOK_URL=https://your-domain.com/api/bot
